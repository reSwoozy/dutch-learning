---
const { headers = [], rows = [] } = Astro.props;
---

{headers.length > 0 && (
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          {headers.map((h) => <th>{h}</th>)}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            {(Array.isArray(row) ? row : Object.values(row)).map((cell) => (
              <td>{cell}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
