---
import { getLocaleFromUrl, localePath } from '@/i18n/utils.js';

const lang = getLocaleFromUrl(Astro.url);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <a href={localePath('/', lang)} class="logo site-footer-brand">
      <span class="logo-mark">NL</span>
      Dutch Learning
    </a>
    <p class="site-footer-meta">
      A1–B2 · Inburgering · Staatsexamen NT2 II · {year}
    </p>
  </div>
</footer>
