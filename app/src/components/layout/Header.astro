---
import { t, localePath } from '@/i18n/utils.js';
import {
  isNavLinkActive,
  isMaterialsSectionActive,
} from '@/lib/nav-active.js';

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
const accountHref = localePath('/account', lang);
const materialsActive = isMaterialsSectionActive(currentPath, lang);

const mainLinks = [
  { href: localePath('/lessons', lang), label: t('nav.lessons', lang) },
  { href: localePath('/grammar', lang), label: t('nav.grammar', lang) },
  { href: localePath('/flashcards', lang), label: t('nav.flashcards', lang) },
  { href: localePath('/tests', lang), label: t('nav.tests', lang) },
];

const materialLinks = [
  { href: localePath('/verbs', lang), label: t('nav.verbs', lang) },
  { href: localePath('/reading', lang), label: t('nav.reading', lang) },
  { href: localePath('/writing', lang), label: t('nav.writing', lang) },
  { href: localePath('/culture', lang), label: t('nav.culture', lang) },
  { href: localePath('/resources', lang), label: t('nav.resources', lang) },
];
---

<header>
  <div class="header-inner">
    <a href={localePath('/', lang)} class="logo">
      <span>NL</span> Dutch Learning
    </a>

    <button
      type="button"
      class="nav-burger"
      id="nav-burger"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span></span><span></span><span></span>
    </button>

    <nav id="nav-drawer" class="nav-drawer" aria-label="Main navigation">
      <div class="nav-main">
        {mainLinks.map((link) => (
          <a
            href={link.href}
            class:list={['nav-link', { active: isNavLinkActive(currentPath, link.href) }]}
          >
            {link.label}
          </a>
        ))}
        <details class="nav-group" id="nav-materials" open={materialsActive ? true : undefined}>
          <summary
            class:list={['nav-link', 'nav-group__trigger', { active: materialsActive }]}
          >
            {t('nav.materials', lang)}
            <svg class="nav-group__chevron" viewBox="0 0 12 12" width="12" height="12" aria-hidden="true">
              <path d="M2 4l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <div class="nav-submenu">
            {materialLinks.map((link) => (
              <a
                href={link.href}
                class:list={['nav-link', { active: isNavLinkActive(currentPath, link.href) }]}
              >
                {link.label}
              </a>
            ))}
          </div>
        </details>
      </div>

      <div class="nav-actions">
        <a
          href={accountHref}
          id="nav-account"
          class:list={['nav-account', { active: isNavLinkActive(currentPath, accountHref) }]}
          title={t('nav.account', lang)}
        >
          <span class="nav-account__avatar" id="nav-account-avatar" aria-hidden="true">
            <svg viewBox="0 0 20 20" width="16" height="16">
              <circle cx="10" cy="7" r="3.2" fill="none" stroke="currentColor" stroke-width="1.6" />
              <path d="M3.5 16.5c1-3 3.6-4.6 6.5-4.6s5.5 1.6 6.5 4.6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
          </span>
          <span class="nav-account__label">{t('nav.account', lang)}</span>
          <span class="nav-account__streak" id="nav-account-streak" hidden>
            <svg viewBox="0 0 14 16" width="11" height="12" aria-hidden="true">
              <path d="M7 1s3 3.2 3 6.2a3 3 0 1 1-6 0c0-1.1.4-2 1-2.8C6 6.4 7 8 7 8s-.5-4 0-7z" fill="currentColor" />
            </svg>
            <span id="nav-account-streak-value">0</span>
          </span>
        </a>
      </div>
    </nav>

    <div class="nav-scrim" id="nav-scrim" hidden></div>
  </div>
</header>

<script>
  const burger = document.getElementById('nav-burger');
  const drawer = document.getElementById('nav-drawer');
  const scrim = document.getElementById('nav-scrim');

  function toggle() {
    const open = drawer.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(open));
    scrim.hidden = !open;
    document.body.classList.toggle('nav-open', open);
  }

  function close() {
    drawer.classList.remove('open');
    burger.setAttribute('aria-expanded', 'false');
    scrim.hidden = true;
    document.body.classList.remove('nav-open');
  }

  burger?.addEventListener('click', toggle);
  scrim?.addEventListener('click', close);

  document.querySelectorAll('#nav-drawer a.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.matchMedia('(max-width: 860px)').matches) close();
    });
  });
</script>
