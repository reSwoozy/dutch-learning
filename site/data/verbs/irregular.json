{
  "groups": [
    { "id": "highly-irregular", "title": "Совсем неправильные", "description": "Самые частотные глаголы с уникальными формами. Нужно запомнить отдельно." },
    { "id": "modal", "title": "Модальные глаголы", "description": "kunnen, moeten, mogen, willen, zullen — все имеют неправильные формы." },
    { "id": "ij-e", "title": "ij → ee → e", "description": "Класс 1: blijven → bleef → gebleven. Один из самых частых паттернов." },
    { "id": "ie-o-o", "title": "ie → oo → o", "description": "Класс 2a: verliezen → verloor → verloren." },
    { "id": "ui-o-o", "title": "ui → oo → o", "description": "Класс 2b: sluiten → sloot → gesloten." },
    { "id": "i-o-o", "title": "i → o → o", "description": "Класс 3a: beginnen → begon → begonnen." },
    { "id": "e-o-o", "title": "e → o → o", "description": "Класс 3b: helpen → hielp → geholpen (частично перекрывается с ie-в-прошедшем)." },
    { "id": "e-a-e", "title": "e → a(a) → e(o)", "description": "Класс 4: nemen → nam/namen → genomen." },
    { "id": "e-a-e5", "title": "e → a(a) → e", "description": "Класс 5: geven → gaf/gaven → gegeven." },
    { "id": "a-ie-a", "title": "a → ie → a", "description": "Класс 6/7: laten → liet → gelaten." },
    { "id": "mixed", "title": "Смешанные", "description": "Окончание прошедшего времени как у слабых (-de/-te), но основа меняется." }
  ],
